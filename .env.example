# 大模型：支持 OpenAI 官方或兼容 OpenAI Chat Completions 协议的第三方服务。
# 请只在本地 .env 中填写真实密钥，不要把密钥写入此示例文件。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_CHAT_COMPLETIONS_URL=
OPENAI_AUTH_HEADER=Authorization
OPENAI_AUTH_SCHEME=Bearer
OPENAI_EXTRA_HEADERS_JSON={}
OPENAI_TIMEOUT_MS=90000

# Python MCP 解释器。可填写 python，或填写本机 Python 3.10 环境的绝对路径。
MCP_PYTHON_EXECUTABLE=python

# 本地金融理论 RAG。留空时使用项目默认目录。
RAG_KNOWLEDGE_DIR=
RAG_DATABASE_PATH=
RAG_TOP_K=5

# 首页监控的 4 只基金。
FUND_WATCHLIST_CODES=510300,161725,005827,110011

# 同花顺 iFinD。只使用东方财富公开行情时可留空。
IFIND_ACCESS_TOKEN=
IFIND_REFRESH_TOKEN=
IFIND_API_BASE_URL=https://quantapi.51ifind.com/api/v1

# 蚂蚁财富或合作金融机构提供的已授权基金接口。
ALIPAY_FUND_API_URL=
ALIPAY_FUND_API_KEY=
ALIPAY_FUND_AUTH_HEADER=Authorization
ALIPAY_FUND_AUTH_SCHEME=Bearer
ALIPAY_FUND_HTTP_METHOD=GET
ALIPAY_FUND_CODE_PARAM=fundCode
ALIPAY_FUND_DATA_PATH=data
ALIPAY_FUND_FIELD_MAP_JSON={"code":"fundCode","name":"fundName","type":"fundType","nav":"nav","navDate":"navDate","dailyGrowthPercent":"dailyGrowthPercent","riskLevel":"riskLevel","saleStatus":"saleStatus","feeRate":"feeRate"}
ALIPAY_FUND_EXTRA_HEADERS_JSON={}
ALIPAY_FUND_STATIC_PARAMS_JSON={}
ALIPAY_FUND_TIMEOUT_SECONDS=20

# Web 服务。
PORT=8787
# 多个公开前端域名用英文逗号分隔；同源和本机 Vite 开发无需填写。
WEB_TRUSTED_ORIGINS=
